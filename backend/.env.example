# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development                         # development | production
SECRET_KEY=change-me-to-a-random-64-char-hex-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Groq ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
GROQ_CHAT_MODEL=llama3-70b-8192

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini              # configurable
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# ── Database (PostgreSQL + pgvector) ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://support:support@postgres:5432/supportdb
SYNC_DATABASE_URL=postgresql://support:support@postgres:5432/supportdb   # Alembic

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── LangSmith (optional — leave blank to disable tracing) ────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ai-support-desk

# ── Agent tuning ──────────────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.6                   # below this → escalate
MAX_TICKET_RETRIES=3

# ── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_TICKETS=10/minute               # per authenticated user
